{
  "defaultProjectTrust": "prompt",
  "agents": {
    "analyst": {
      "description": "Read-only \u2014 code review, exploration, research",
      "model": "xiaomi-token-plan-sgp/mimo-v2.5-pro",
      "thinkingLevel": "high",
      "tools": [
        "read",
        "bash"
      ],
      "timeoutMs": 120000
    },
    "scout": {
      "description": "Fast codebase reconnaissance \u2014 pattern search, file discovery",
      "model": "xiaomi-token-plan-sgp/mimo-v2.5-pro",
      "thinkingLevel": "minimal",
      "tools": [
        "read",
        "bash"
      ],
      "timeoutMs": 60000
    },
    "reviewer-correctness": {
      "description": "Logic errors, edge cases, contract violations",
      "model": "xiaomi-token-plan-sgp/mimo-v2.5-pro",
      "thinkingLevel": "high",
      "tools": [
        "read",
        "bash"
      ],
      "timeoutMs": 120000
    },
    "reviewer-security": {
      "description": "Injection, auth bypass, data exposure",
      "model": "xiaomi-token-plan-sgp/mimo-v2.5-pro",
      "thinkingLevel": "high",
      "tools": [
        "read",
        "bash"
      ],
      "timeoutMs": 120000
    },
    "reviewer-performance": {
      "description": "Algorithmic complexity, memory, blocking I/O",
      "model": "xiaomi-token-plan-sgp/mimo-v2.5-pro",
      "thinkingLevel": "high",
      "tools": [
        "read",
        "bash"
      ],
      "timeoutMs": 120000
    }
  },
  "honcho": {
    "workspaceId": "pi-core-beads",
    "aiPeerId": "pi",
    "userPeerId": "user",
    "sessionStrategy": "repo",
    "contextTokens": 1200,
    "maxMessageLength": 8000,
    "searchLimit": 8,
    "toolPreviewLength": 500,
    "reasoningLevel": "medium",
    "reasoningLevelCap": "max",
    "observationMode": "unified",
    "baseURL": "http://localhost:8000"
  },
  "defaultThinkingLevel": "medium",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "enabledModels": [
    "xiaomi-token-plan-sgp/mimo-v2.5-pro",
    "xiaomi-token-plan-sgp/mimo-v2.5",
    "openai-codex/gpt-5.3-codex-spark",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.5",
    "makora/deepseek-ai/DeepSeek-V4-Flash",
    "makora/deepseek-ai/DeepSeek-V4-Pro",
    "makora/MiniMaxAI/MiniMax-M3-MXFP8",
    "makora/moonshotai/Kimi-K2.7-Code",
    "makora/nvidia/Kimi-K2.6-NVFP4",
    "makora/zai-org/GLM-5.1-FP8"
  ]
}
